// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  imageUrl  String
  bio       String?
  phone     String?
  whatsapp  String?
  createdAt DateTime @default(now())
}

model Event {
  id            String   @id @default(uuid())
  title         String
  category      String
  date          DateTime
  time          String?
  location      String
  imageUrl      String
  galleryImages String[]
  actionUrl     String?
  description   String
  createdAt     DateTime @default(now())
}

model MembershipApplication {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  whatsapp  String
  company   String?
  industry  String?
  message   String
  timestamp DateTime @default(now())
}

model ContactQuery {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  timestamp DateTime @default(now())
}
